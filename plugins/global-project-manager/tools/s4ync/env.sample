# MinIO/S3 Configuration
# MINIO_ENDPOINT can include protocol (http:// or https://)
# If no protocol is specified, defaults to https://
# Examples:
#   - http://minio.example.com:9000  (uses HTTP)
#   - https://minio.example.com:9000 (uses HTTPS)
#   - minio.example.com:9000         (defaults to HTTPS)
export MINIO_ENDPOINT="minio.doolta.com:9000"
export MINIO_ACCESS_KEY="your-access-key"
export MINIO_SECRET_KEY="your-secret-key"
export MINIO_BUCKET="global-projects"  # Optional, defaults to "global-projects"
